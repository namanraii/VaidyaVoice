# VaidyaVoice Environment Variables
# Copy this to .env and fill in your real credentials

# ───────────────────────────────────────────────────────────
# Sarvam AI (already configured in config.py)
# ───────────────────────────────────────────────────────────
# SARVAM_API_KEY=sk_ei79ezzp_eibYoBTtsV07nFOuQXFpK15c

# ───────────────────────────────────────────────────────────
# Neo4j AuraDB (FILL THESE IN)
# ───────────────────────────────────────────────────────────
NEO4J_URI=neo4j+s://YOUR_INSTANCE.databases.neo4j.io:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=YOUR_PASSWORD_HERE

# ───────────────────────────────────────────────────────────
# Redis (Render auto-provides on private network)
# ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ───────────────────────────────────────────────────────────
# Postgres (Render auto-provides on private network)
# ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://localhost/vaidyavoice

# ───────────────────────────────────────────────────────────
# Google Maps (OPTIONAL — for emergency hospital finder)
# ───────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_KEY

# ───────────────────────────────────────────────────────────
# Render Workflows (auto-detected when deployed on Render)
# ───────────────────────────────────────────────────────────
RENDER_WORKFLOW_SERVICE=vaidyavoice-workflow
